# ========================================
# AI Reading Companion — 环境变量
# ========================================
# 使用方法：复制此文件为 .env，填入你的 API Key
#   cp .env.example .env
# ========================================

# 服务器端口（可选，默认 3005）
PORT=3005

# SQLite 数据库路径（可选，默认 backend/reading.db）
# Railway 部署时建议设为 /data/reading.db（持久卷挂载点）
DATABASE_PATH=./reading.db

# CORS 允许的前端域名（生产环境必填，留空则允许所有来源）
# 示例：CORS_ORIGIN=https://ai-reading-companion.vercel.app
CORS_ORIGIN=

# JWT 签名密钥（生产环境务必使用随机字符串，至少 32 字符）
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret

# -------------------------------------------
# OpenAI API Key（用于 AI 摘要功能）
# -------------------------------------------
# 获取步骤：
#   1. 访问 https://platform.openai.com/api-keys
#   2. 登录（或注册）OpenAI 账号
#   3. 点击 "+ Create new secret key"
#   4. 复制生成的 key（格式：sk-proj-... 或 sk-...）
#   5. 粘贴到下方，替换示例值
#
# 注意：
#   - Key 以 "sk-" 开头
#   - 请确保账号有可用余额或免费额度
#   - 模型：gpt-3.5-turbo（成本低、速度快）
#   - 此文件不会被提交到 Git（已在 .gitignore 中）
#
# ---- OpenAI（用于摘要和推荐） ----
OPENAI_API_KEY=sk-your-openai-api-key-here

# ---- DeepSeek（用于联网找书） ----
# 获取步骤：访问 https://platform.deepseek.com/api_keys 创建 API Key
# 注意：DeepSeek API 兼容 OpenAI SDK，base_url 指向 https://api.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
